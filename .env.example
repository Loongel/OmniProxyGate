# OmniProxyGate local Compose / Swarm example environment.
# For Swarm, copy deploy/omni-proxygate.env.example instead.

OMNI_IMAGE=ghcr.io/OWNER/REPO:latest
OMNI_STACK_NAME=omni-proxygate
OMNI_NODE_HOSTNAME=hd01

# Published ports.
OMNI_HTTP_PORT=80
OMNI_HTTPS_PORT=443
OMNI_UI_PORT=18081
OMNI_UI_SCHEME=https

# Runtime mode.
OMNI_RUN_GATEWAY=true
OMNI_RUN_UI=true
OMNI_WEB_UI_ENABLED=true

# UI/API security.
COOKIE_SECURE=true
OMNI_ADMIN_USER=admin
# Quote values containing $, !, #, spaces, or quotes if this file is sourced by a shell.
OMNI_ADMIN_PASSWORD=
OMNI_ADMIN_FORCE_PASSWORD_RESET=false
OMNI_AGENT_API_TOKEN=
