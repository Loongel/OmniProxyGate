# Published image and deployment
OMNI_IMAGE=ghcr.io/OWNER/REPO:latest
OMNI_STACK_NAME=omni-proxygate
OMNI_DATA_ROOT=/opt/omni-proxygate
OMNI_HTTP_PORT=80
OMNI_HTTPS_PORT=443
OMNI_UI_PORT=18081

# Single-image runtime switches
OMNI_RUN_GATEWAY=true
OMNI_RUN_UI=true
OMNI_WEB_UI_ENABLED=true

# UI / API
DATA_DIR=/data
COOKIE_SECURE=false
SESSION_DAYS=7
PBKDF2_ITERATIONS=260000
OMNI_ADMIN_USER=admin
OMNI_ADMIN_PASSWORD=
OMNI_ADMIN_FORCE_PASSWORD_RESET=false
OMNI_AGENT_API_TOKEN=

# Nginx control. Single-image deployments use local commands and do not need docker.sock.
NGINX_CONTAINER=
USE_DOCKER_CLI=false
NGINX_TEST_COMMAND=nginx -t
NGINX_RELOAD_COMMAND=nginx -s reload
DRY_RUN=false

# Gateway defaults
LISTEN_ADDRESS_MODE=split
ENABLE_HTTP3=true
DEFAULT_TCP_PORT=443
DEFAULT_UDP_PORT=443
INTERNAL_HTTP_HOST=127.0.0.1
INTERNAL_HTTP_PORT=8443
