# OmniProxyGate Swarm deployment environment.
# Usage:
#   cp deploy/omni-proxygate.env.example /opt/omni-proxygate/omni.env
#   edit /opt/omni-proxygate/omni.env
#   set -a; . /opt/omni-proxygate/omni.env; set +a
#   ./scripts/deploy-omni-proxygate-stack.sh

# Required: image produced by GitHub Actions.
OMNI_IMAGE=ghcr.io/OWNER/REPO:latest

# Stack and placement.
OMNI_STACK_NAME=omni-proxygate
# Pin the gateway to the node that owns the public 80/443 ports and local volumes.
OMNI_NODE_HOSTNAME=hd01

# Published ports.
OMNI_HTTP_PORT=80
OMNI_HTTPS_PORT=443
# UI/API is normally kept on a private/admin port or behind another reverse proxy.
OMNI_UI_PORT=18081

# Runtime mode. Default runs gateway + Web UI/API in one container.
OMNI_RUN_GATEWAY=true
OMNI_RUN_UI=true
OMNI_WEB_UI_ENABLED=true

# UI/API security.
# Use true when the UI/API is only accessed through HTTPS; keep false for plain local HTTP tests.
COOKIE_SECURE=false
OMNI_ADMIN_USER=admin
# Required for unattended first boot or password reset; leave blank to initialize manually in UI.
OMNI_ADMIN_PASSWORD=
# Set true only when intentionally rotating the admin password from this env file.
OMNI_ADMIN_FORCE_PASSWORD_RESET=false
# Optional token for Agent CLI/API access. Use a long random value if enabled.
OMNI_AGENT_API_TOKEN=

# Optional: override Docker named volume names. Usually leave commented.
# OMNI_DATA_VOLUME=omni_proxygate_data
# OMNI_NGINX_HTTP_VOLUME=omni_proxygate_nginx_http
# OMNI_NGINX_STREAM_VOLUME=omni_proxygate_nginx_stream
# OMNI_CERTS_VOLUME=omni_proxygate_certs
# OMNI_LOGS_VOLUME=omni_proxygate_logs
