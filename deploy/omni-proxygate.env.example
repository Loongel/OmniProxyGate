# Image published by GitHub Actions. Replace OWNER/REPO with your GitHub repository.
OMNI_IMAGE=ghcr.io/OWNER/REPO:latest
OMNI_STACK_NAME=omni-proxygate
OMNI_DATA_ROOT=/opt/omni-proxygate

# Published ports. For direct public service use 80/443/8080 or place UI behind another route.
OMNI_HTTP_PORT=80
OMNI_HTTPS_PORT=443
OMNI_UI_PORT=18081

# Runtime switches for the single image.
OMNI_RUN_GATEWAY=true
OMNI_RUN_UI=true
OMNI_WEB_UI_ENABLED=true

# API/UI security.
COOKIE_SECURE=false
OMNI_ADMIN_USER=admin
OMNI_ADMIN_PASSWORD=
OMNI_ADMIN_FORCE_PASSWORD_RESET=false
OMNI_AGENT_API_TOKEN=

# Gateway defaults.
LISTEN_ADDRESS_MODE=split
ENABLE_HTTP3=true
DEFAULT_TCP_PORT=443
DEFAULT_UDP_PORT=443
INTERNAL_HTTP_HOST=127.0.0.1
INTERNAL_HTTP_PORT=8443
